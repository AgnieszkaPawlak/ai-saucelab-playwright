{
  "name": "saucelab",
  "version": "1.0.0",
  "description": "Automatyzacja testów SauceDemo (Playwright + POM)",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:characterization": "playwright test --grep @characterization",
    "test:nf": "playwright test --grep @nf-",
    "test:ui": "playwright test --ui",
    "lint": "eslint .",
    "report": "playwright show-report"
  },
  "keywords": ["playwright", "saucedemo", "e2e"],
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
