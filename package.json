{
  "name": "saucelab",
  "version": "1.0.0",
  "description": "Automatyzacja testów SauceDemo (Playwright + POM)",
  "private": true,
  "scripts": {
    "test": "npm run test:readonly && npm run test:mutating",
    "test:readonly": "playwright test --grep @readonly --workers=4 --project=chromium",
    "test:mutating": "playwright test --grep @mutating --workers=1 --project=chromium",
    "test:smoke": "playwright test --grep \"(?=.*@smoke)(?=.*@readonly)\" --workers=4 --project=chromium && playwright test --grep \"(?=.*@smoke)(?=.*@mutating)\" --workers=1 --project=chromium",
    "test:regression": "playwright test --grep \"(?=.*@regression)(?=.*@readonly)\" --workers=4 --project=chromium && playwright test --grep \"(?=.*@regression)(?=.*@mutating)\" --workers=1 --project=chromium",
    "test:characterization": "playwright test --grep @characterization --workers=1 --project=chromium",
    "test:nf": "playwright test --grep \"(?=.*@nf)(?=.*@readonly)\" --workers=4 --project=chromium && playwright test --grep \"(?=.*@nf)(?=.*@mutating)\" --workers=1 --project=chromium",
    "test:cross-browser": "playwright test --grep @nf-cross-browser --workers=1",
    "test:ui": "playwright test --ui",
    "lint": "eslint .",
    "report": "playwright show-report"
  },
  "keywords": ["playwright", "saucedemo", "e2e"],
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
